{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codex.example/schemas/release-manifest.schema.json",
  "title": "CODEX Release Manifest",
  "type": "object",
  "required": ["id", "name", "version", "status", "releasedAt", "components", "artifacts", "conformanceFixtures"],
  "properties": {
    "$schema": {"type": "string"},
    "formatVersion": {"type": "string", "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$"},
    "id": {"type": "string", "pattern": "^[A-Z][A-Z0-9]{1,15}-[0-9]{4,}$"},
    "name": {"type": "string", "minLength": 1},
    "version": {"type": "string", "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$"},
    "status": {"enum": ["draft", "released", "deprecated", "withdrawn"]},
    "releasedAt": {"type": ["string", "null"], "format": "date-time"},
    "components": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {"type": "string"}
    },
    "artifacts": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "conformanceFixtures": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "checksums": {
      "type": "object",
      "propertyNames": {"minLength": 1},
      "additionalProperties": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
    }
  },
  "additionalProperties": false
}
