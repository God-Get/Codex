{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codex-spec.org/schemas/cli-envelope.schema.json",
  "title": "CODEX CLI API Envelope",
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["ok", "apiVersion", "command", "result"],
      "properties": {
        "ok": { "const": true },
        "apiVersion": { "const": "0.2" },
        "command": { "type": "string", "minLength": 1 },
        "result": {}
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["ok", "apiVersion", "command", "diagnostic"],
      "properties": {
        "ok": { "const": false },
        "apiVersion": { "const": "0.2" },
        "command": { "type": "string", "minLength": 1 },
        "diagnostic": {
          "type": "object",
          "additionalProperties": false,
          "required": ["code", "message"],
          "properties": {
            "code": { "type": "string", "minLength": 1 },
            "message": { "type": "string", "minLength": 1 },
            "source": { "type": "string", "minLength": 1 },
            "line": { "type": "integer", "minimum": 1 },
            "column": { "type": "integer", "minimum": 1 }
          }
        }
      }
    }
  ]
}
