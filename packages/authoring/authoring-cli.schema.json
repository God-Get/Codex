{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codex-spec.org/schemas/authoring-cli.schema.json",
  "title": "CODEX Authoring CLI Envelope",
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["ok", "apiVersion", "command", "result"],
      "properties": {
        "ok": { "const": true },
        "apiVersion": { "const": "0.2" },
        "command": { "const": "authoring.compile" },
        "result": {
          "type": "object",
          "additionalProperties": false,
          "required": ["project", "projectId", "objectCount"],
          "properties": {
            "outputPath": { "type": "string", "minLength": 1 },
            "project": { "type": "object" },
            "projectId": { "type": "string", "minLength": 1 },
            "objectCount": { "type": "integer", "minimum": 0 },
            "profile": { "type": "string", "minLength": 1 },
            "profileChain": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            },
            "validation": { "type": "object" }
          }
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["ok", "apiVersion", "command", "diagnostic"],
      "properties": {
        "ok": { "const": false },
        "apiVersion": { "const": "0.2" },
        "command": { "const": "authoring.compile" },
        "diagnostic": {
          "$ref": "./authoring-diagnostic.schema.json"
        }
      }
    }
  ]
}
