{
  "$schema": "../../schemas/translation-automation.schema.json",
  "provider": {
    "kind": "static",
    "dataFile": "fixtures/static-provider.json"
  },
  "glossaryFile": "fixtures/glossary.json",
  "memoryFile": ".codex-ci/translation-memory.json",
