{
  "name": "codex",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "workspaces": ["packages/*", "apps/*"],
  "scripts": {
    "build": "tsc -b",
    "check": "tsc -b --pretty false",
    "authoring:compile": "node packages/authoring/dist/cli.js examples/authoring --output=examples/authoring/project.json",
    "validate": "node apps/cli/dist/index.js validate examples/minimal-project.json",
    "validate:strict": "node apps/cli/dist/index.js validate examples/minimal-project.json --profile=strict",
    "validate:hermetica": "node apps/cli/dist/index.js validate examples/minimal-project.json --profile=hermetica",
    "validate:json": "node apps/cli/dist/index.js validate examples/minimal-project.json --json",
    "validate:sarif": "node apps/cli/dist/index.js validate examples/minimal-project.json --sarif --output=codex-results.sarif",
    "validate:schema-invalid": "node apps/cli/dist/index.js validate examples/invalid-schema.json --json",
    "profiles:list": "node apps/cli/dist/index.js profiles list",
    "profiles:inspect": "node apps/cli/dist/index.js profiles inspect hermetica",
    "profiles:validate": "node apps/cli/dist/index.js profiles validate hermetica",
    "inspect": "node apps/cli/dist/index.js inspect examples/minimal-project.json",
    "inspect:json": "node apps/cli/dist/index.js inspect examples/minimal-project.json --json",
    "graph": "node apps/cli/dist/index.js graph examples/minimal-project.json --format=json",
    "graph:dot": "node apps/cli/dist/index.js graph examples/minimal-project.json --format=dot",
    "graph:filtered": "node apps/cli/dist/index.js graph examples/minimal-project.json --format=json --relations=translates,derivedFrom",
    "graph:write": "node apps/cli/dist/index.js graph examples/minimal-project.json --format=dot --output=codex-graph.dot",
    "diagnostics": "node apps/cli/dist/index.js diagnostics",
    "diagnostics:json": "node apps/cli/dist/index.js diagnostics --json",
    "release:prepare": "node apps/cli/dist/index.js release prepare releases/0.2.0/manifest.json --output=releases/0.2.0/manifest.prepared.json",
    "release:verify": "node apps/cli/dist/index.js release verify releases/0.2.0/manifest.prepared.json",
    "release:verify:json": "node apps/cli/dist/index.js release verify releases/0.2.0/manifest.prepared.json --json",
    "release:keygen": "node apps/cli/dist/index.js release keygen --private-key=.codex-ci/private.pem --public-key=.codex-ci/public.pem",
    "release:sign": "node apps/cli/dist/index.js release sign releases/0.2.0/manifest.prepared.json --private-key=.codex-ci/private.pem --output=.codex-ci/manifest.sig.json",
    "release:signature-verify": "node apps/cli/dist/index.js release signature-verify releases/0.2.0/manifest.prepared.json --signature=.codex-ci/manifest.sig.json --public-key=.codex-ci/public.pem",
    "package:build": "node apps/cli/dist/index.js package build releases/0.2.0/manifest.prepared.json --output=codex-package-0.2.0",
    "package:build:json": "node apps/cli/dist/index.js package build releases/0.2.0/manifest.prepared.json --output=codex-package-0.2.0 --json",
    "package:verify": "node apps/cli/dist/index.js package verify codex-package-0.2.0",
    "package:verify:json": "node apps/cli/dist/index.js package verify codex-package-0.2.0 --json",
    "package:unpack": "node apps/cli/dist/index.js package unpack codex-package-0.2.0 --output=codex-unpacked-0.2.0",
    "doctor": "node apps/cli/dist/index.js doctor",
    "test": "npm run build && node --test tests/**/*.test.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
